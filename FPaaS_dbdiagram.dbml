// =============================================================
// FPaaS (Financial Platform as a Service) — Database Design
// Translated from Japanese ER diagram discussion document
// =============================================================

// ─────────────────────────────────────────────
// CORE DOMAIN: Customer & Partner
// ─────────────────────────────────────────────

Table customer {
  pf_id varchar [pk, note: 'Platform ID — unique across all partners']
  temporary_pf_id varchar [note: 'Temporary PF ID issued before full registration']
  temporary_pf_id_expiry datetime [note: 'Expiry datetime for temporary PF ID']
  name_kana varchar [note: 'Name in Katakana']
  name_kanji varchar [note: 'Name in Kanji']
  date_of_birth date
  address varchar
  gender varchar
  identity_verification_status varchar [note: 'eKYC verification status']
  status varchar [note: 'Applying / Awaiting ID verification / Active / Withdrawn']
  temporary_pf_id_issued_at datetime
  full_id_activated_at datetime [note: 'Datetime when temporary ID was promoted to full ID']

  Note: '''
    Core model managing Platform IDs.
    PF ID is unique across ALL partners (cross-partner uniqueness).

    DESIGN DISCUSSION:
    - [nakui] For name-matching (名寄せ) searches, consider whether phone number,
      kana name, DOB, hashed My Number, or LIQUID-retrievable My Number identifier are needed.
    - [nakui] Should we store personal info obtainable from partners (e.g. name, phone, address)?
    - [washio] Is PF really the right place to reference personal info?
      Delegating to partner apps might be preferable.
    - [washio] If user identity can be guaranteed via an external identifier (like LIQUID's),
      perhaps PF doesn't need to hold personal info at all.
    - [nakui] Only email address is kept up-to-date on PF side.
      Other attributes are saved only as-of application time and NOT refreshed.
    - [nakui] My Number is retrievable via LIQUID but is too sensitive to store in PF (NBS decision).
  '''
}

Table customer_partner {
  pf_id varchar [ref: > customer.pf_id, note: 'FK to customer']
  partner_id varchar [ref: > partner.partner_id, note: 'FK to partner']
  partner_customer_id varchar [note: 'Customer ID in partner system']
  email varchar [note: 'Only attribute kept up-to-date on PF side']
  status varchar
  device_token varchar
  access_token varchar
  refresh_token varchar
  refresh_token_expiry datetime
  cancellation_datetime datetime
  currently_in_use_flag boolean [note: '(TBD) Flag indicating active usage']

  indexes {
    (pf_id, partner_id, partner_customer_id) [pk, note: 'Composite unique key']
  }

  Note: '''
    Many-to-Many junction: Customer ↔ Partner.
    Uniqueness: PF_ID + Partner_ID + Partner_Customer_ID.

    DESIGN DISCUSSION:
    - [nakui] SDK session ↔ PF_ID binding is done via this table.
      (ref: miro board uXjVG7kvVdA)
    - [washio] Need to monitor WHICH partner and WHICH account a user is actively using.
      The "currently_in_use" flag is needed for privilege/benefit management
      (to know which account is in use for reward tracking, etc.).
    - [nakui] Must support re-opening an account after cancellation
      via a different route by the same user.
    - [nakui] Can surrogate keys + logging replace flag-based management
      for better auditability?
  '''
}

Table customer_financial_service {
  pf_id varchar [ref: > customer.pf_id]
  financial_service_id varchar [ref: > financial_service.financial_service_id]
  financial_service_customer_id varchar [note: 'Customer ID within the financial service']
  partner_id varchar [ref: > partner.partner_id]
  application_id varchar [ref: > application_status.application_id]
  status varchar
  access_token varchar
  refresh_token varchar
  linked_date date
  unlinked_date date
  link_origin varchar [note: 'Where the linking was initiated from']
  last_access_datetime datetime

  indexes {
    (pf_id, financial_service_id, partner_id) [pk]
  }

  Note: '''
    Many-to-Many junction: Customer ↔ Financial Service.
    Separate from partner_available_financial_service because the services
    a partner CAN offer ≠ the services a customer ACTUALLY uses.

    DESIGN DISCUSSION:
    - For SBI Shinsei Bank: PID = Power Direct ID = branch_number + account_number (10 digits).
    - [nakui] "Receipt number" (受付番号) might belong on the customer side rather than here.
    - [nakui] How much financial-service-provided data should we persist in DB?
      Principle: PF should NOT retain customer info — just format JSON and pass through to frontend.
    - [nakui] Record is created/persisted ONLY AFTER receiving the back-office processing response
      (not at the time of application submission).
  '''
}

// ─────────────────────────────────────────────
// PARTNER & FINANCIAL SERVICE MASTERS
// ─────────────────────────────────────────────

Table partner {
  partner_id varchar [pk]
  partner_code varchar [unique, note: 'Business code for the partner']
  name varchar
  status varchar
  partnership_start_date date
  native_app_init_key varchar [note: '(DEPRECATED) Was for app initialization']

  Note: '''
    Master table for partners using FPaaS (e.g. Chubu Electric Power).

    DESIGN DISCUSSION:
    - [nakui] The native_app_init_key is NO LONGER NEEDED.
      Authentication switched to Signed JWT issued by partner and verified server-side.
  '''
}

Table partner_available_financial_service {
  partner_id varchar [ref: > partner.partner_id]
  financial_service_id varchar [ref: > financial_service.financial_service_id]
  enabled_flag boolean
  validity_period_start datetime [note: '(TBD) Start of availability window']
  validity_period_end datetime [note: '(TBD) End of availability window']

  indexes {
    (partner_id, financial_service_id) [pk]
  }

  Note: '''
    1-to-Many: Partner → Available Financial Services.
    Defines which financial services each partner is allowed to offer.
    This is a CAPABILITY mapping, not actual customer usage.
  '''
}

Table financial_service {
  financial_service_id varchar [pk]
  name varchar [note: 'e.g. SBI Shinsei Bank, SBI Securities']
  authorization_method varchar [note: 'OAuth, etc.']
  enabled_flag boolean

  Note: '''
    Master table for financial services integrated with FPaaS
    (e.g. SBI Shinsei Bank, SBI Securities, etc.).
  '''
}

// ─────────────────────────────────────────────
// APPLICATION / ENROLLMENT FLOW
// ─────────────────────────────────────────────

Table application_status {
  application_id varchar [pk, note: '''
    Identifies one application flow:
    a specific customer, via a specific partner,
    applying for a specific financial service.
  ''']
  pf_id varchar [ref: > customer.pf_id]
  partner_id varchar [ref: > partner.partner_id]
  receipt_number varchar [note: 'Assigned by back-office processing']
  status varchar [note: 'Submitted / Received / Rejected / Send Failed / Cancelled']
  application_datetime datetime
  backoffice_response_received_at datetime
  cancelled_at datetime

  Note: '''
    Manages PF ID and its application status.
    State is updated via status-update API calls from the back-office processing service.
    - Record is CREATED when transmission to back-office begins
      (i.e. at the moment the decision to send is made).
    - Statuses: Submitted | Received | Rejected | Send Failed | Cancelled.
    - IMPORTANT: State consistency with back-office service must be maintained.

    DESIGN DISCUSSION:
    - [nakui] Retry strategy needs consideration: server-side retry vs end-user retry.
      Recovery paths and timeout handling for back-office processing must be designed.
  '''
}

Table application_detail {
  application_id varchar [ref: > application_status.application_id]
  financial_service_id varchar [ref: > financial_service.financial_service_id, note: '(TBD) confirm FK']
  status varchar
  duplicate_prevention_key varchar [unique, note: '''
    Generated from hash of:
    application_id + pf_id + partner_id + partner_customer_id
  ''']
  backoffice_response_received_at datetime
  cancelled_at datetime

  indexes {
    (application_id, financial_service_id) [pk]
  }

  Note: '''
    Tracks which financial services are included in each application
    and their individual statuses.
    One application_id can map to 1+ financial_service_ids.
  '''
}

Table application_content {
  application_content_id varchar [pk]
  application_content json [note: 'Full form data stored as JSON']
  application_id varchar [ref: > application_status.application_id]
  created_at datetime

  Note: '''
    Persists application form data.

    DESIGN DISCUSSION:
    - [nakui] If content is stored as JSON, consider merging this into
      the application_status entity to reduce complexity.
    - [nakui → nakazawa] "Storing as JSON is fine" (confirmed 2026/03/13).
  '''
}

Table terms_agreement_status {
  application_content_id varchar [ref: > application_content.application_content_id]
  terms_source varchar [note: 'External (VC, FX) or Internal']
  terms_master_id varchar [ref: > fpaas_terms_master.terms_id]
  agreement_result boolean
  agreed_at datetime

  Note: '''
    Persists the result of terms agreement actions.

    DESIGN DISCUSSION:
    - Whether to keep this in a separate table or inline is TBD.
    - [2026/03/02 MT] Financial service terms are, in principle,
      NOT managed by FPaaS (managed by each financial service provider).
  '''
}

Table application_info_attribute_master {
  id varchar [pk]
  attribute_name varchar
  hierarchy_level int [note: 'Nesting depth in the attribute structure']
  effective_from datetime
  effective_until datetime [note: '(TBD) For periodic/versioned attributes']

  Note: '''
    Master defining the attributes/structure of persisted application info.
    Controls which fields are captured and at what nesting level.
  '''
}

// ─────────────────────────────────────────────
// IDENTITY VERIFICATION (LIQUID eKYC)
// ─────────────────────────────────────────────

Table identity_verification_liquid {
  identity_verification_id varchar [pk]
  pf_id varchar [ref: > customer.pf_id]
  integration_id varchar [note: '''
    LIQUID-side identifier. Issued/numbered by FPaaS.
    PF_ID : Integration_ID = 1 : N (required by LIQUID spec).
  ''']
  ekyc_method varchar [note: 'Methods: Ka / Ru / He (カ・ル・ヘ)']
  document_type varchar [note: 'My Number Card / Drivers License']
  liquid_receipt_number varchar
  verification_status varchar [note: 'Review/screening status from LIQUID']
  validity_status varchar
  application_datetime datetime
  result_received_at datetime
  partner_partner_customer_id varchar [note: 'Links to customer_partner record']

  Note: '''
    Manages identity verification via LIQUID eKYC.
    Links PF_ID to LIQUID eKYC applications and their statuses.
    PF_ID ↔ Integration_ID is 1:N (LIQUID requirement).

    DESIGN DISCUSSION:
    - Integration ID is ISSUED BY FPaaS (not by LIQUID).
    - Schema must support 1:N relationship between PF_ID and Integration_ID.
    - Ref: LIQUID_eKYC_Web_Implementation_Spec_v1.2.2.pdf Page 9.

    LIQUID eKYC "RE-USE" SEMANTICS (from NotebookLM analysis):
    - "Re-use" means "re-application (issuing a new URL)".
    - If previous result was NG or URL expired → same integration_id CAN be reused
      to issue a new capture URL.
    - If result was OK → re-application (overwrite) is BLOCKED for that integration_id.
    - The integration_id remains usable as a DATA QUERY KEY even after OK completion.
    - Completed results and captured images can always be retrieved via
      Connector API (result retrieval API, image data retrieval API).
  '''
}

Table auth_face_liquid {
  identity_verification_id varchar [ref: > identity_verification_liquid.identity_verification_id]
  face_auth_type varchar [note: 'eKYC or Auth ID']
  access_token varchar
  refresh_token varchar
  refresh_token_expiry datetime

  Note: '''
    Manages tokens issued by LIQUID Auth Face authentication.

    DESIGN DISCUSSION:
    - Access token is REQUIRED for identity verification application
      and verification-completion inquiries.
  '''
}

// ─────────────────────────────────────────────
// TERMS / LEGAL
// ─────────────────────────────────────────────

Table fpaas_terms_master {
  terms_id varchar [pk]
  terms_type varchar
  title varchar
  content text
  financial_service_id varchar [ref: > financial_service.financial_service_id, note: 'Nullable — only if service-specific']
  partner_id varchar [ref: > partner.partner_id, note: 'Nullable — only if partner-specific']
  version int
  effective_from datetime
  effective_until datetime
  status varchar

  Note: '''
    Manages terms-of-service text/content.
    Supports versioning and time-bounded validity.
  '''
}

// ─────────────────────────────────────────────
// ADMIN / BACK-OFFICE
// ─────────────────────────────────────────────

Table admin_user {
  admin_user_id varchar [pk]
  email varchar
  hashed_password varchar
  name varchar
  status varchar
  role_type varchar [note: '(TBD) Permission/role classification']
  organization_id varchar [ref: > organization.organization_id, note: '(TBD)']

  Note: '''
    User accounts for the admin management console.
  '''
}

Table organization {
  organization_id varchar [pk]
  name varchar
  status varchar

  Note: '''
    Organizations that admin users belong to.

    DESIGN DISCUSSION:
    - [nakui] Need to decide whether to create this entity
      to improve availability and traceability when multiple
      organizations use the admin console.
  '''
}

// ─────────────────────────────────────────────
// CMS / NOTIFICATIONS
// ─────────────────────────────────────────────

Table bulletin_master {
  bulletin_id varchar [pk]
  title varchar
  content text
  published_at datetime
  partner_id varchar [ref: > partner.partner_id, note: '(TBD) Nullable — partner-specific bulletins']

  Note: '''
    Bulletins displayed in the PF App.
    Used for system-level restriction/change announcements.
  '''
}

Table notification_master {
  notification_id varchar [pk]
  title varchar
  content text
  published_at datetime
  partner_id varchar [ref: > partner.partner_id, note: '(TBD) Nullable — partner-specific notifications']

  Note: '''
    Notifications/announcements displayed in the PF App.
    Used for campaigns and similar promotional content.
  '''
}

Table email_master {
  email_id varchar [pk]
  email_template text

  Note: '''
    Email templates sent from PF.
  '''
}

Table content_master {
  main_image varchar
  sub_image varchar
  app_id varchar [ref: > native_app_management.app_id]

  Note: '''
    CMS content displayed in the PF App.
  '''
}

Table native_app_management {
  app_id varchar [pk]
  os_type varchar [note: 'iOS / Android']
  version_name varchar
  version_number varchar [note: 'Internal build number']
  published_at datetime

  Note: '''
    Manages native app versions and release tracking.
  '''
}

// ─────────────────────────────────────────────
// BILLING / FEES
// ─────────────────────────────────────────────

Table fee_master {
  id varchar [pk]
  partner_id varchar [ref: > partner.partner_id]
  effective_until datetime
  fee_category varchar [note: 'Type of fee/charge']
  markup_rate_or_fixed_value decimal [note: 'Percentage markup OR fixed fee amount']
  version int
  operational_start_datetime datetime

  Note: '''
    Manages pricing parameters for settlement/billing.
    Supports versioned fee structures per partner.
  '''
}

// =============================================================
// RELATIONSHIP SUMMARY (for visual clarity)
// =============================================================
// customer 1──* customer_partner *──1 partner
// customer 1──* customer_financial_service *──1 financial_service
// customer_financial_service *──1 partner
// partner 1──* partner_available_financial_service *──1 financial_service
// customer 1──* application_status *──1 partner
// application_status 1──* application_detail *──1 financial_service
// application_status 1──1 application_content
// application_content 1──* terms_agreement_status
// customer 1──* identity_verification_liquid
// identity_verification_liquid 1──1 auth_face_liquid
// =============================================================
